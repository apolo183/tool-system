{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/apolo183/tool-system/harness/task_manifest.schema.json",
  "$comment": "repo_rel_path: harness/task_manifest.schema.json; role: schema contract; purpose: validate agent task manifests before any patch or repo write workflow; author: ChatGPT / apolo183; created_at: 2026-07-05 20:20 UTC+08:00; updated_at: 2026-07-05 20:20 UTC+08:00",
  "title": "tool-system task manifest schema",
  "type": "object",
  "required": [
    "task_id",
    "task_type",
    "target_repo",
    "target_branch",
    "phase",
    "approved_blueprint_refs",
    "scope",
    "evidence",
    "allowed_files",
    "forbidden_files",
    "write_mode",
    "verification",
    "rollback",
    "approval"
  ],
  "additionalProperties": false,
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,120}$"
    },
    "task_type": {
      "type": "string",
      "enum": ["read_only_audit", "docs_add", "docs_modify", "code_add", "code_modify", "test_add", "ci_add", "policy_add", "dry_run"]
    },
    "target_repo": {
      "type": "string",
      "enum": ["apolo183/tool-system", "apolo183/finance-os"]
    },
    "target_branch": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "type": "string",
      "minLength": 2
    },
    "approved_blueprint_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["repo", "path", "section_or_key"],
        "additionalProperties": false,
        "properties": {
          "repo": {"type": "string"},
          "path": {"type": "string"},
          "section_or_key": {"type": "string"},
          "line_range": {"type": "string"}
        }
      }
    },
    "scope": {
      "type": "object",
      "required": ["summary", "in_scope", "out_of_scope"],
      "additionalProperties": false,
      "properties": {
        "summary": {"type": "string", "minLength": 10},
        "in_scope": {
          "type": "array",
          "items": {"type": "string"}
        },
        "out_of_scope": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["repo", "path", "why_relevant"],
        "additionalProperties": false,
        "properties": {
          "repo": {"type": "string"},
          "path": {"type": "string"},
          "line_range": {"type": "string"},
          "commit_sha": {"type": "string"},
          "why_relevant": {"type": "string", "minLength": 5}
        }
      }
    },
    "allowed_files": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "forbidden_files": {
      "type": "array",
      "items": {"type": "string"}
    },
    "write_mode": {
      "type": "string",
      "enum": ["read_only", "patch_only", "pull_request", "direct_bootstrap"]
    },
    "verification": {
      "type": "object",
      "required": ["commands", "pass_conditions"],
      "additionalProperties": false,
      "properties": {
        "commands": {
          "type": "array",
          "items": {"type": "string"}
        },
        "pass_conditions": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "rollback": {
      "type": "object",
      "required": ["method", "reference"],
      "additionalProperties": false,
      "properties": {
        "method": {"type": "string", "enum": ["git_revert", "patch_reverse", "delete_added_files", "manual_review"]},
        "reference": {"type": "string", "minLength": 3}
      }
    },
    "approval": {
      "type": "object",
      "required": ["required", "approved_by", "approval_source", "approved_at"],
      "additionalProperties": false,
      "properties": {
        "required": {"const": true},
        "approved_by": {"type": "string", "minLength": 1},
        "approval_source": {"type": "string", "minLength": 1},
        "approved_at": {"type": "string", "minLength": 10}
      }
    }
  }
}
